# ===== NATURAL DELAY SETTINGS =====
# Membuat pola pengiriman lebih natural seperti manusia

# Base delay default (ms) - bisa di-override per broadcast
BROADCAST_BASE_DELAY=5000

# Jitter range (persentase dari base delay)
# Contoh: -0.4 sampai 0.6 = delay antara 60% - 160% dari base
DELAY_JITTER_MIN=-0.4
DELAY_JITTER_MAX=0.6

# Cluster pattern - grup pesan dengan jeda panjang
CLUSTER_ENABLED=true
CLUSTER_SIZE_MIN=3
CLUSTER_SIZE_MAX=7
CLUSTER_PAUSE_MIN=10000
CLUSTER_PAUSE_MAX=20000

# Progressive slowdown - delay bertambah seiring jumlah pesan
PROGRESSIVE_ENABLED=true
PROGRESSIVE_THRESHOLD=20
PROGRESSIVE_INCREMENT=0.05

# Typing simulation - delay berdasarkan panjang pesan
TYPING_ENABLED=true
TYPING_SPEED=3
TYPING_MAX_DELAY=10000
TYPING_JITTER_MIN=0.5
TYPING_JITTER_MAX=1.5

# Typing indicator - tampilkan "sedang mengetik..." di WhatsApp
# Set true untuk tampilkan, false untuk hanya delay
TYPING_INDICATOR_ENABLED=false

API_RATE_WINDOW_MS=60000
API_RATE_MAX_SEND=30
API_RATE_MAX_BROADCAST=10